// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  ADMIN
  AUTHOR
  READER
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentProvider {
  RAZORPAY
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PAST_DUE
}

enum PlanInterval {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubscriptionPlanName {
  STANDARD
  PREMIUM
  ENTERPRISE
}

enum StoryAccessReason {
  SUBSCRIPTION
  DIRECT_PURCHASE // extensible for future per-story purchase
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  firstName String
  lastName  String
  password  String

  // Email verification
  isEmailVerified                Boolean   @default(false)
  emailVerificationToken         String?   @unique
  emailVerificationTokenExpiresAt DateTime?

  // Password reset
  forgotPasswordToken            String?   @unique
  forgotPasswordTokenExpiresAt   DateTime?

  // Auth
  refreshToken                   String?   @unique
  refreshTokenExpiresAt          DateTime?

  // Soft delete
  deletedAt DateTime?

  // Relations
  roles         UserToRole[]
  stories       Story[]        @relation("StoryAuthor")
  storiesCreated Story[]       @relation("StoryCreatedBy")
  storiesUpdated Story[]       @relation("StoryUpdatedBy")
  likes         Like[]
  comments      Comment[]
  payments      Payment[]
  subscriptions Subscription[]
  storyAccess   StoryAccess[]
  bookmarks     Bookmark[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@map("users")
}

// ─────────────────────────────────────────
// ROLES (RBAC)
// ─────────────────────────────────────────

model UserToRole {
  id     Int  @id @default(autoincrement())
  userId Int
  role   Role

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, role])
  @@map("user_to_roles")
}

// ─────────────────────────────────────────
// STORY
// ─────────────────────────────────────────

model Story {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique  // SEO-friendly URL e.g. "my-first-story"
  description String?
  content     String
  coverImage  String?           // URL to cover image

  isPublished Boolean  @default(false)
  isPremium   Boolean  @default(false) // requires active subscription to read

  viewCount   Int      @default(0)     // analytics: track views

  // Soft delete
  deletedAt   DateTime?

  // Author (the user who owns the story)
  authorId    Int
  author      User     @relation("StoryAuthor", fields: [authorId], references: [id])

  // Audit trail
  createdById Int?
  createdBy   User?    @relation("StoryCreatedBy", fields: [createdById], references: [id])
  updatedById Int?
  updatedBy   User?    @relation("StoryUpdatedBy", fields: [updatedById], references: [id])

  // Relations
  tags        StoryTag[]
  likes       Like[]
  comments    Comment[]
  access      StoryAccess[]
  bookmarks   Bookmark[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([authorId])
  @@index([isPublished, isPremium])
  @@index([slug])
  @@map("stories")
}

// ─────────────────────────────────────────
// TAGS  (for search/filter feature)
// ─────────────────────────────────────────

model Tag {
  id    Int       @id @default(autoincrement())
  name  String    @unique
  slug  String    @unique

  stories StoryTag[]

  @@map("tags")
}

model StoryTag {
  storyId Int
  tagId   Int

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([storyId, tagId])
  @@map("story_tags")
}

// ─────────────────────────────────────────
// ENGAGEMENT: LIKES & COMMENTS
// ─────────────────────────────────────────

model Like {
  id      Int @id @default(autoincrement())
  userId  Int
  storyId Int

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, storyId])
  @@index([storyId])
  @@map("likes")
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  userId    Int
  storyId   Int

  // Self-referencing for nested replies
  parentId  Int?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")

  // Soft delete
  deletedAt DateTime?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storyId])
  @@index([parentId])
  @@map("comments")
}

// ─────────────────────────────────────────
// BOOKMARKS
// ─────────────────────────────────────────

model Bookmark {
  id      Int @id @default(autoincrement())
  userId  Int
  storyId Int

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, storyId])
  @@index([userId])
  @@map("bookmarks")
}

// ─────────────────────────────────────────
// SUBSCRIPTION PLANS
// ─────────────────────────────────────────

model Plan {
  id          Int          @id @default(autoincrement())
  name        SubscriptionPlanName       @unique 
  description String?
  price       Float                 // in smallest currency unit or decimal
  currency    String       @default("INR")
  interval    PlanInterval          // MONTHLY | QUARTERLY | YEARLY
  intervalCount Int        @default(1) // e.g. every 1 month

  isActive    Boolean      @default(true)

  // Razorpay plan ID if using Razorpay Subscriptions API
  razorpayPlanId String?   @unique

  subscriptions Subscription[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("plans")
}

// ─────────────────────────────────────────
// USER SUBSCRIPTIONS
// ─────────────────────────────────────────

model Subscription {
  id        Int                @id @default(autoincrement())
  userId    Int
  planId    Int

  status    SubscriptionStatus @default(ACTIVE)

  // Billing window
  startDate DateTime
  endDate   DateTime           // when current period ends

  // Razorpay subscription tracking
  razorpaySubscriptionId String? @unique

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      Plan    @relation(fields: [planId], references: [id])
  payments  Payment[]
  access    StoryAccess[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([endDate])        // useful for cron jobs that expire subscriptions
  @@map("subscriptions")
}

// ─────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────

model Payment {
  id             Int             @id @default(autoincrement())
  userId         Int
  subscriptionId Int?            // null if it's a one-off (future extensibility)

  amount         Float
  currency       String          @default("INR")
  provider       PaymentProvider
  status         PaymentStatus   @default(PENDING)

  // Razorpay-specific fields
  razorpayOrderId    String?     @unique
  razorpayPaymentId  String?     @unique
  razorpaySignature  String?     // store for webhook verification

  // Metadata for failed/refund scenarios
  failureReason  String?
  refundedAt     DateTime?

  user         User          @relation(fields: [userId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([razorpayOrderId])
  @@map("payments")
}

// ─────────────────────────────────────────
// STORY ACCESS (gate-keeping premium content)
// ─────────────────────────────────────────

// This table answers: "Does user X have access to story Y, and why?"
// For subscription model: a record is created for each premium story
// when a subscription becomes ACTIVE, OR checked dynamically via
// active subscription lookup (preferred for scale — see note below).

model StoryAccess {
  id             Int               @id @default(autoincrement())
  userId         Int
  storyId        Int
  subscriptionId Int?              // which subscription granted access
  reason         StoryAccessReason @default(SUBSCRIPTION)

  // Access window mirrors subscription window
  accessGrantedAt DateTime         @default(now())
  accessExpiresAt DateTime?        // null = permanent (e.g. one-time purchase)

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  story        Story         @relation(fields: [storyId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@unique([userId, storyId])
  @@index([userId])
  @@index([accessExpiresAt])
  @@map("story_access")
}