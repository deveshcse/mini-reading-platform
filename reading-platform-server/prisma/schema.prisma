// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  ADMIN
  AUTHOR
  READER
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentProvider {
  RAZORPAY
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PAST_DUE
}

enum PlanInterval {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubscriptionPlanName {
  STANDARD
  PREMIUM
  ENTERPRISE
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  firstName String
  lastName  String

  accounts       Account[]
  stories        Story[]        @relation("StoryAuthor")
  storiesCreated Story[]        @relation("StoryCreatedBy")
  storiesUpdated Story[]        @relation("StoryUpdatedBy")
  likes          Like[]
  comments       Comment[]
  payments       Payment[]
  subscriptions  Subscription[]
  bookmarks      Bookmark[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([email])
  @@map("users")
}

// ─────────────────────────────────────────
// ACCOUNT (credentials + auth tokens, scoped per role)
// ─────────────────────────────────────────

model Account {
  id     Int  @id @default(autoincrement())
  userId Int
  role   Role

  password String

  // Email verification
  isEmailVerified                 Boolean   @default(false)
  emailVerificationToken          String?   @unique
  emailVerificationTokenExpiresAt DateTime?

  // Password reset
  forgotPasswordToken          String?   @unique
  forgotPasswordTokenExpiresAt DateTime?

  // Refresh token
  refreshToken          String?   @unique
  refreshTokenExpiresAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, role])
  @@index([userId])
  @@map("accounts")
}

// ─────────────────────────────────────────
// STORY
// ─────────────────────────────────────────

model Story {
  id          Int     @id @default(autoincrement())
  title       String
  description String?
  content     String
  coverImage  String?

  isPublished Boolean @default(false)
  isPremium   Boolean @default(false)
  viewCount   Int     @default(0)

  authorId Int
  author   User @relation("StoryAuthor", fields: [authorId], references: [id])

  createdById Int?
  createdBy   User? @relation("StoryCreatedBy", fields: [createdById], references: [id])
  updatedById Int?
  updatedBy   User? @relation("StoryUpdatedBy", fields: [updatedById], references: [id])

  likes     Like[]
  comments  Comment[]
  bookmarks Bookmark[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([authorId])
  @@index([isPublished, isPremium])
  @@map("stories")
}

// ─────────────────────────────────────────
// ENGAGEMENT
// ─────────────────────────────────────────

model Like {
  id      Int @id @default(autoincrement())
  userId  Int
  storyId Int

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, storyId])
  @@index([storyId])
  @@map("likes")
}

model Comment {
  id      Int    @id @default(autoincrement())
  content String
  userId  Int
  storyId Int

  parentId Int?
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentReplies")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([storyId])
  @@index([parentId])
  @@map("comments")
}

// ─────────────────────────────────────────
// BOOKMARKS
// ─────────────────────────────────────────

model Bookmark {
  id      Int @id @default(autoincrement())
  userId  Int
  storyId Int

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, storyId])
  @@index([userId])
  @@map("bookmarks")
}

// ─────────────────────────────────────────
// PLANS
// ─────────────────────────────────────────

model Plan {
  id            Int                  @id @default(autoincrement())
  name          SubscriptionPlanName @unique
  description   String?
  price         Float
  currency      String               @default("INR")
  interval      PlanInterval
  intervalCount Int                  @default(1)
  isActive      Boolean              @default(true)

  razorpayPlanId String? @unique

  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("plans")
}

// ─────────────────────────────────────────
// SUBSCRIPTIONS
// ─────────────────────────────────────────

model Subscription {
  id     Int                @id @default(autoincrement())
  userId Int
  planId Int
  status SubscriptionStatus @default(ACTIVE)

  startDate DateTime
  endDate   DateTime

  razorpaySubscriptionId String? @unique

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan     Plan      @relation(fields: [planId], references: [id])
  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([endDate])
  @@map("subscriptions")
}

// ─────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────

model Payment {
  id             Int             @id @default(autoincrement())
  userId         Int
  subscriptionId Int?
  amount         Float
  currency       String          @default("INR")
  provider       PaymentProvider
  status         PaymentStatus   @default(PENDING)

  razorpayOrderId   String? @unique
  razorpayPaymentId String? @unique
  razorpaySignature String?

  failureReason String?
  refundedAt    DateTime?

  user         User          @relation(fields: [userId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([razorpayOrderId])
  @@map("payments")
}